{
  "name": "skilled-pr",
  "version": "0.2.0",
  "description": "Open review transport for AI-native development. Attestation that your code was reviewed by AI skills.",
  "type": "module",
  "bin": {
    "skilled-pr": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude-code",
    "github",
    "attestation",
    "developer-tools"
  ],
  "author": "Feliche-Demian Netliukh",
  "license": "MIT",
  "homepage": "https://github.com/Demianeen/skilled-pr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Demianeen/skilled-pr.git"
  },
  "bugs": {
    "url": "https://github.com/Demianeen/skilled-pr/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsonc-parser": "^3.3.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^4.3.6"
  }
}
